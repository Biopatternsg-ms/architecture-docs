                    "step" : {
                      "$ref" : "#/components/schemas/PipelineSteps"
                    },
                    "expertObjects" : {
                      "type" : "array",
                      "items" : {
                        "$ref" : "#/components/schemas/ExpertObjectConfig"
                      }
                    },
                    "transcriptionFactorConfig" : {
                      "$ref" : "#/components/schemas/TranscriptionFactorConfig"

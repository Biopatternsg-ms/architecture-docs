{
  "openapi" : "3.1.0",
  "components" : {
    "schemas" : {
      "ExpertObjectConfig" : {
        "type" : "object",
        "properties" : {
          "uniprotId" : {
            "type" : "string"
          },
          "hgncId" : {
            "type" : "string"
          },
          "symbol" : {
            "type" : "string"
          }
        }
      },
      "Genome" : {
        "type" : "string",
        "enum" : [ "HG38", "HG19" ]
      },
      "LoginRequest" : {
        "type" : "object",
        "properties" : {
          "user" : {
            "type" : "string"
          },
          "pass" : {
            "type" : "string"
          }
        }
      },
      "NetworkConfig" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "userId" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "description" : {
            "type" : "string"
          }
        }
      },
      "PipelineConfig" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          },
          "description" : {
            "type" : "string"
          },
          "networkId" : {
            "type" : "string"
          },
          "levels" : {
            "type" : "integer",
            "format" : "int32"
          },
          "step" : {
            "$ref" : "#/components/schemas/PipelineSteps"
          },
          "expertObjects" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/ExpertObjectConfig"
            }
          },
          "transcriptionFactorConfig" : {
            "$ref" : "#/components/schemas/TranscriptionFactorConfig"
          }
        }
      },
      "PipelineStepRequest" : {
        "type" : "object",
        "properties" : {
          "step" : {
            "$ref" : "#/components/schemas/PipelineSteps"
          }
        }
      },
      "PipelineSteps" : {
        "type" : "string",
        "enum" : [ "CONFIG", "LAUNCH", "TRANSCRIPTION_FACTOR", "EXPERT_OBJECTS", "SEARCH_LEVELS" ]
      },
      "Strand" : {
        "type" : "string",
        "enum" : [ "POSITIVE", "NEGATIVE" ]
      },
      "TranscriptionFactorConfig" : {
        "type" : "object",
        "properties" : {
          "promoterRegion" : {
            "type" : "string"
          },
          "reliability" : {
            "type" : "integer",
            "format" : "int32"
          },
          "start" : {
            "type" : "number"
          },
          "end" : {
            "type" : "number"
          },
          "genome" : {
            "$ref" : "#/components/schemas/Genome"
          },
          "track" : {
            "type" : "string"
          },
          "identity" : {
            "type" : "number",
            "format" : "float"
          },
          "chromosome" : {
            "type" : "string"
          },
          "strand" : {
            "$ref" : "#/components/schemas/Strand"
          },
          "sources" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/TranscriptionFactorSource"
            }
          }
        }
      },
      "TranscriptionFactorSource" : {
        "type" : "string",
        "enum" : [ "TFBIND", "JASPAR" ]
      },
      "UserRequest" : {
        "type" : "object",
        "properties" : {
          "username" : {
            "type" : "string"
          },
          "firstName" : {
            "type" : "string"
          },
          "lastName" : {
            "type" : "string"
          },
          "password" : {
            "type" : "string"
          }
        }
      }
    }
  },
  "paths" : {
    "/config-and-control/auth" : {
      "post" : {
        "summary" : "User authentication",
        "description" : "Authenticates a user with provided credentials and returns an authentication token.",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/LoginRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "User successfully authenticated",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "object",
                  "description" : "Authentication token response",
                  "properties" : {
                    "access_token" : {
                      "type" : "string"
                    },
                    "refresh_token" : {
                      "type" : "string"
                    },
                    "token_type" : {
                      "type" : "string"
                    },
                    "id_token" : {
                      "type" : "string"
                    },
                    "expires_in" : {
                      "type" : "integer",
                      "format" : "int64"
                    }
                  }
                }
              }
            }
          },
          "400" : {
            "description" : "Bad Request"
          }
        },
        "tags" : [ "Auth Controller" ]
      }
    },
    "/config-and-control/networks" : {
      "put" : {
        "summary" : "Update network configuration",
        "description" : "Updates an existing network configuration for biological data processing.",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/NetworkConfig"
              }

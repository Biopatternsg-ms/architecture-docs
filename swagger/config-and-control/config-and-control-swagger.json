        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/PipelineConfig"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "Pipeline configuration successfully created",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "object",
                  "description" : "Created pipeline configuration",
                  "properties" : {
                    "id" : {
                      "type" : "string"
                    },
                    "name" : {
                      "type" : "string"
                    },
                    "description" : {
                      "type" : "string"
                    },
                    "networkId" : {
                      "type" : "string"
                    },
                    "levels" : {
                      "type" : "integer",
                      "format" : "int32"
                    },
                    "step" : {
                      "$ref" : "#/components/schemas/PipelineSteps"
                    },
                    "expertObjects" : {
                      "type" : "array",
                      "items" : {
                        "$ref" : "#/components/schemas/ExpertObjectConfig"

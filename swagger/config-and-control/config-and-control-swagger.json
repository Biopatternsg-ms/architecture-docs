    "/config-and-control/pipelines/launch" : {
      "post" : {
        "summary" : "Launch pipeline execution",
        "description" : "Launches the execution of a configured pipeline for biological data processing.",
        "parameters" : [ {
          "name" : "id",
          "in" : "query",
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "202" : {
            "description" : "Pipeline successfully launched for execution",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "string",
                  "description" : "Success message with pipeline ID"
                }
              }
            }
          }
        },
        "tags" : [ "Pipeline Controller" ]
      }
    },
    "/config-and-control/pipelines/update-step/{id}" : {
      "patch" : {
        "summary" : "Update pipeline step",
        "description" : "Updates a specific step within a pipeline configuration.",
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/PipelineStepRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "202" : {
            "description" : "Pipeline step successfully updated",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "string",
                  "description" : "Success message"
                }
              }
            }
          }
        },
        "tags" : [ "Pipeline Controller" ]
      }
    },
